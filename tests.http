### 1. Check Available Slots for Tomorrow
GET http://localhost:5000/api/bookings/vet/available?date=2026-04-03
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5Y2U0ZmI3MjAyNzBkYmNmZGEyOTcwZCIsInJvbGUiOiJWZXQiLCJpYXQiOjE3NzUxMjg2ODUsImV4cCI6MTc3NTczMzQ4NX0.E_AW5ktH2inAJS7JBl7C0BS87Pq7fwe5OSTWKXY04jQ

###

### 2. Lock a Slot (This should create a temporary booking)
POST http://localhost:5000/api/bookings/vet/lock
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5Y2U0ZmI3MjAyNzBkYmNmZGEyOTcwZCIsInJvbGUiOiJWZXQiLCJpYXQiOjE3NzUxMjg2ODUsImV4cCI6MTc3NTczMzQ4NX0.E_AW5ktH2inAJS7JBl7C0BS87Pq7fwe5OSTWKXY04jQ

{
  "date": "2026-04-03",
  "timeSlot": "11:00"
}

###

### 3. Check Available Slots Again (10:00 should now be MISSING)
GET http://localhost:5000/api/bookings/vet/available?date=2026-04-03
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5Y2U0ZmI3MjAyNzBkYmNmZGEyOTcwZCIsInJvbGUiOiJWZXQiLCJpYXQiOjE3NzUxMjg2ODUsImV4cCI6MTc3NTczMzQ4NX0.E_AW5ktH2inAJS7JBl7C0BS87Pq7fwe5OSTWKXY04jQ

###

### 4. Confirm the Booking (Finalize it with Rex's ID)
# REPLACE <NEW_BOOKING_ID> with the _id returned from Step 2
POST http://localhost:5000/api/bookings/vet/confirm
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5Y2U0ZmI3MjAyNzBkYmNmZGEyOTcwZCIsInJvbGUiOiJWZXQiLCJpYXQiOjE3NzUxMjg2ODUsImV4cCI6MTc3NTczMzQ4NX0.E_AW5ktH2inAJS7JBl7C0BS87Pq7fwe5OSTWKXY04jQ

{
  "bookingId": "69ce52a63fd335e2542355d5",
  "petId": "69ce51ec3fd335e2542355c3"
}




